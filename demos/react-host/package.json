{
  "name": "react-host",
  "version": "1.0.0",
  "private": true,
  "description": "React demo host for embedding a Mendix app in a dashboard shell",
  "type": "module",
  "scripts": {
    "build": "rollup --config rollup.config.ts --configPlugin typescript",
    "start": "rollup --config rollup.config.ts --configPlugin typescript --watch"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "rollup": "^4.53.2",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-serve": "^3.0.0",
    "typescript": "^6.0.3"
  }
}
